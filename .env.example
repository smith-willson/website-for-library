# Copy to .env and fill in your REAL Gmail details (required for OTP emails)

# Session secret (change in production)
SESSION_SECRET=lms-secret-key-change-me

# Gmail — REQUIRED for OTP emails to reach your phone/inbox
# 1. Turn on 2-Step Verification on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Paste your Gmail and the 16-character app password below
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Google Sign-In — optional OAuth 2.0 Client ID (Web application)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
